# Site Configuration
NEXT_PUBLIC_SITE_URL="https://www.neshatamar.com"  # Required: Your production site URL (used for SEO, sitemaps, Open Graph)

# Email Service (Required for lead capture form)
RESEND_API_KEY="your_resend_api_key_here"          # Required: Resend API key for email notifications. Format: re_...
LEAD_RECIPIENT_EMAIL="your_email@example.com"      # Optional: Email address to receive lead notifications. Defaults to Nissimkrispiltamar@gmail.com
RESEND_FROM_EMAIL="Nes HaTamar <leads@neshatamr.com>"  # Optional: Sender email for notifications. Must be verified in Resend.

# PayMe Payment Gateway
PAYME_SELLER_ID="your_payme_seller_id"             # Required in production: Your PayMe seller ID
PAYME_USE_SANDBOX="false"                          # Optional: set "true" to point at PayMe sandbox

# Upstash Redis (required for coupons and HFD order persistence)
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_rest_token"

# HFD courier integration
# Contact HFD support (https://api.hfd.co.il/docs) to receive:
#   - a Bearer token (valid 2 years)
#   - your clientNumber
#   - the shipmentTypeCode and cargoTypeHaloch that match your contract
# ordererName is your company name as it should appear on the label (<= 10 chars).
HFD_API_URL="https://api.hfd.co.il/rest/v2"        # Optional: defaults to the production URL
HFD_API_TOKEN="your_hfd_bearer_token"              # Required: Bearer token from HFD support
HFD_CLIENT_NUMBER="0"                              # Required: HFD customer number (numeric)
HFD_SHIPMENT_TYPE_CODE="0"                         # Required: shipment type code from HFD support
HFD_CARGO_TYPE_HALOCH="0"                          # Required: outbound cargo type code from HFD support
HFD_ORDERER_NAME="Nes HaTamar"                     # Required: your company name on the label (<= 10 chars)

# Admin (optional)
ADMIN_PASSWORD_HASH="bcrypt_hash_of_admin_password"

# API Keys (Required to enable respective provider)
ANTHROPIC_API_KEY="your_anthropic_api_key_here"       # Required: Format: sk-ant-api03-...
PERPLEXITY_API_KEY="your_perplexity_api_key_here"     # Optional: Format: pplx-...
OPENAI_API_KEY="your_openai_api_key_here"             # Optional, for OpenAI models. Format: sk-proj-...
GOOGLE_API_KEY="your_google_api_key_here"             # Optional, for Google Gemini models.
MISTRAL_API_KEY="your_mistral_key_here"               # Optional, for Mistral AI models.
XAI_API_KEY="YOUR_XAI_KEY_HERE"                       # Optional, for xAI AI models.
GROQ_API_KEY="YOUR_GROQ_KEY_HERE"                     # Optional, for Groq models.
OPENROUTER_API_KEY="YOUR_OPENROUTER_KEY_HERE"         # Optional, for OpenRouter models.
AZURE_OPENAI_API_KEY="your_azure_key_here"            # Optional, for Azure OpenAI models (requires endpoint in .taskmaster/config.json).
OLLAMA_API_KEY="your_ollama_api_key_here"             # Optional: For remote Ollama servers that require authentication.
GITHUB_API_KEY="your_github_api_key_here"             # Optional: For GitHub import/export features. Format: ghp_... or github_pat_...
