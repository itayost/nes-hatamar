                                        "sale_price": "1000",
                                        "currency": "ILS",
                                        "product_name": "Shirt",
                                        "language": "en",
                                        "sale_type": "token",
                                        "sale_payment_method": "il-direct-debit",
                                        "sale_return_url": "https://sport5.co.il"
                                    }
